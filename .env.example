# ===========================
# 앱 기본 설정
# ===========================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Quote Viewer

# ===========================
# Notion CMS (서버 전용)
# - NOTION_TOKEN: Notion Integration 의 Internal Integration Token (ntn_/secret_ 접두)
# - NOTION_DATABASE_ID: 견적 메타데이터(Invoice) DB 의 ID (32자 hex, 하이픈 유무 무관)
# - NOTION_ITEMS_DATABASE_ID: 견적 항목(Items) DB 의 ID (Invoice 와 Relation 일대다)
# - 세 값 모두 NEXT_PUBLIC_ 접두사 금지(클라이언트 노출 시 토큰 유출).
# - 셋업 절차: docs/SETUP_NOTION.md 참조 (Invoice + Items 2개 DB 분리 채택)
# ===========================
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_ITEMS_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ===========================
# Revalidate Webhook
# - /api/revalidate 호출 시 Authorization: Bearer <값> 헤더로 인증
# - Make / Zapier 등 외부 자동화에서 Notion 변경 트리거 시 호출
# - 강한 무작위 32자 이상 권장: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ===========================
NOTION_REVALIDATE_SECRET=change-me-to-a-long-random-string

# ===========================
# 관리자 인증 (Phase 3 / T3.1 — 서버 전용)
# - ADMIN_PASSWORD: /admin/login 비밀번호 평문. 운영자 본인만 아는 강한 값.
# - ADMIN_SESSION_SECRET: 세션 쿠키 HMAC 서명 키. 강한 무작위 32자 이상 권장.
#     생성: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# - 둘 다 NEXT_PUBLIC_ 접두사 절대 금지(클라이언트 노출 시 인증 우회).
# - production 은 Vercel 프로젝트 환경변수에도 동일하게 등록해야 한다.
# ===========================
ADMIN_PASSWORD=change-me-to-a-strong-admin-password
ADMIN_SESSION_SECRET=change-me-to-a-long-random-hex-string

# ===========================
# 회귀 시드 슬러그 (T1.2-test / T1.3-test 가 사용)
# - Notion Quotes DB 의 시드 견적 2건의 Slug 값 (Notion Formula 가 자동 생성한 32자 hex)
# - 셋업 절차: docs/SETUP_NOTION.md 참조
# ===========================
SEED_SLUG_ACTIVE=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SEED_SLUG_EXPIRED=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
