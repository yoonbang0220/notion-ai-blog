# ===========================
# 앱 기본 설정
# ===========================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=AI 학습 블로그

# ===========================
# Notion CMS (서버 전용)
# - NOTION_TOKEN: Notion Integration 의 Internal Integration Token
# - NOTION_DATABASE_ID: 글을 담는 Posts DB 의 ID (32자 hex, 하이픈 유무 무관)
# - 두 값 모두 NEXT_PUBLIC_ 접두사 금지(클라이언트 노출 시 토큰 유출).
# ===========================
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ===========================
# Revalidate Webhook (선택)
# - /api/revalidate 호출 시 Authorization: Bearer <값> 헤더로 인증
# ===========================
NOTION_REVALIDATE_SECRET=change-me-to-a-long-random-string
